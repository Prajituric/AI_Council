# AI Council Desktop Agent — Configuration
# Copy this file to .env and fill in your values

# Your Anthropic API key (needs access to claude-opus-4-5 with computer-use beta)
ANTHROPIC_API_KEY=sk-ant-...

# Your Supabase project URL and anon key (same values as in Netlify env vars)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...

# The user ID this agent should listen for
# Must match the userId stored in your AI Council session
AGENT_USER_ID=your-username

# Secret for verifying commands (should match JWT_SECRET on your Netlify deployment)
# Leave empty to skip verification (not recommended in production)
AGENT_SECRET=

# Max number of computer-use loop steps before giving up (default: 20)
AGENT_MAX_STEPS=20

# Ask for confirmation before destructive shell commands (default: true)
AGENT_CONFIRM_DESTRUCTIVE=true
