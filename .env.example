# ================================================================
#  GenX (AI Council) — Environment Variables
#  Add these in: Netlify → Site Settings → Environment Variables
#  For local dev: copy this to .env
# ================================================================

# ── AI PROVIDER (required) ─────────────────────────────────────
# Every model call in the app routes through OpenRouter with this ONE key —
# Claude, GPT, Gemini, DeepSeek, Grok, Llama, and Mistral are all reached
# through the same endpoint (https://openrouter.ai/api/v1/chat/completions).
# Get a key + add credits at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# ── LEGACY NATIVE PROVIDER KEYS (deprecated, no longer used) ───
# The app no longer calls these vendor APIs directly — everything goes
# through OPENROUTER_API_KEY above. Left here only as a reference in case
# you fork the project back to native per-vendor calls; safe to delete.
# ANTHROPIC_API_KEY=sk-ant-api03-...     # https://console.anthropic.com/settings/keys
# OPENAI_API_KEY=sk-proj-...             # https://platform.openai.com/api-keys
# GEMINI_API_KEY=AIzaSy...               # https://aistudio.google.com/app/apikey
# DEEPSEEK_API_KEY=sk-...                # https://platform.deepseek.com/api_keys
# XAI_API_KEY=xai-...                    # https://console.x.ai
# GROQ_API_KEY=gsk_...                   # https://console.groq.com/keys
# MISTRAL_API_KEY=...                    # https://console.mistral.ai/api-keys
# TOGETHER_API_KEY=...                   # https://api.together.xyz

# ── SUPABASE (database — multi-device) ────────────────────────
# Create project at https://supabase.com → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── CLOUDFLARE R2 (file storage — permanent, max size) ─────────
# Create bucket at https://dash.cloudflare.com → R2 → Create bucket
# Then: R2 → Manage R2 API tokens → Create API token (Object Read & Write)
R2_ACCOUNT_ID=abc123def456...            # Cloudflare Dashboard → right sidebar
R2_ACCESS_KEY_ID=...                     # R2 API token → Access Key ID
R2_SECRET_ACCESS_KEY=...                 # R2 API token → Secret Access Key
R2_BUCKET_NAME=ai-council-files          # Your bucket name
R2_PUBLIC_URL=https://pub-xxx.r2.dev     # Bucket → Settings → Public URL (enable public access)

# ── MULTI-TENANCY (3 preset accounts) ─────────────────────────
# Change these before deploying! IDs are lowercase, no spaces.
USER1_ID=andrei
USER1_NAME=Andrei
USER1_PASS=council2025

USER2_ID=ana
USER2_NAME=Ana
USER2_PASS=pass2025

USER3_ID=guest
USER3_NAME=Guest
USER3_PASS=guest2025

# ── SKILLS / LEARN ────────────────────────────────────────────
# Optional: increases GitHub API rate limit for skill learning (60→5000 req/hr)
GITHUB_TOKEN=ghp_...     # github.com → Settings → Developer settings → Personal access tokens

# ── FEATURE FLAGS ─────────────────────────────────────────────
# Set to "true" to enable auto-evaluation step after synthesis (uses extra Claude tokens)
ENABLE_EVALUATION=true
